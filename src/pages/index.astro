---
import '../styles/main.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Hand Pose Playground</title>
	</head>
	<body>
		<div id="app">
			<nav class="top-nav">
				<a href="/" class="active">Hands</a>
				<a href="/face">Face</a>
			</nav>

			<fps-monitor style="position: absolute; top: 20px; left: 20px; z-index: 1000;"></fps-monitor>

			<button id="debug-toggle">Debug View</button>
			<div id="debug-sidebar" class="hidden">
				<h3>Debug Info</h3>
				<div id="debug-content">
					<div class="debug-section">
						<h4>System Control</h4>
						<button id="camera-toggle-btn">Stop Camera</button>
					</div>
					<div class="debug-section">
						<h4>Gesture Control</h4>
						<div id="gesture-selector-sidebar">
							<label for="gesture-type">Active Gesture:</label>
							<select id="gesture-type">
								<option value="pinch">Pinch</option>
								<option value="finger-curve">Finger Curve</option>
							</select>
						</div>
					</div>
					<div class="debug-section">
						<h4>Model State</h4>
						<p>Status: <span id="debug-status">Initializing...</span></p>
					</div>

					<!-- Hand 1 Debug -->
					<div class="debug-hand-container">
						<div class="debug-section">
							<h4>Hand 1</h4>
							<p>Pos: <span id="debug-pos-0">N/A</span></p>
							<p>Pinching: <span id="debug-pinching-0">No</span></p>
							<p>Drag: <span id="debug-drag-state-0">IDLE</span></p>
							<p>Target: <span id="debug-drag-target-0">None</span></p>
							<div id="debug-gesture-data-0" class="mini-debug">N/A</div>
						</div>
					</div>

					<!-- Hand 2 Debug -->
					<div class="debug-hand-container">
						<div class="debug-section">
							<h4>Hand 2</h4>
							<p>Pos: <span id="debug-pos-1">N/A</span></p>
							<p>Pinching: <span id="debug-pinching-1">No</span></p>
							<p>Drag: <span id="debug-drag-state-1">IDLE</span></p>
							<p>Target: <span id="debug-drag-target-1">None</span></p>
							<div id="debug-gesture-data-1" class="mini-debug">N/A</div>
						</div>
					</div>

					<div class="debug-section">
						<h4>Links</h4>
						<a href="https://github.com/forestinthetree/hand-pose-playground" target="_blank" class="debug-link">GitHub Repository</a>
					</div>
				</div>
			</div>
			<div id="paused-overlay">
				<h2>Paused</h2>
				<p>Click anywhere to resume</p>
			</div>
			<canvas id="hand-canvas"></canvas>
			<video id="webcam" autoplay playsinline></video>
			<div id="interaction-layer">
				<div id="box1" class="draggable">Red</div>
				<div id="box2" class="draggable">Green</div>
				<div id="box3" class="draggable">Blue</div>
			</div>
			<div id="cursor-0" class="cursor"></div>
			<div id="cursor-1" class="cursor"></div>
			<div id="status">Initializing Handpose...</div>
		</div>

		<script>
			import { init } from '../scripts/main.js';
			init();
		</script>
	</body>
</html>

