---
import '../styles/main.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Hand Pose Playground</title>
	</head>
	<body>
		<div id="app">
			<fps-monitor style="position: absolute; top: 20px; left: 20px; z-index: 1000;"></fps-monitor>
			
			<button id="debug-toggle">Debug View</button>
			<div id="debug-sidebar" class="hidden">
				<h3>Debug Info</h3>
				<div id="debug-content">
					<div class="debug-section">
						<h4>Gesture Control</h4>
						<div id="gesture-selector-sidebar">
							<label for="gesture-type">Active Gesture:</label>
							<select id="gesture-type">
								<option value="pinch">Pinch</option>
								<option value="finger-curve">Finger Curve</option>
							</select>
						</div>
					</div>
					<div class="debug-section">
						<h4>Model State</h4>
						<p>Status: <span id="debug-status">Initializing...</span></p>
					</div>
					<div class="debug-section">
						<h4>Hand Tracking</h4>
						<p>Position: <span id="debug-pos">N/A</span></p>
						<p>Pinching: <span id="debug-pinching">No</span></p>
					</div>
					<div class="debug-section">
						<h4>Drag & Drop</h4>
						<p>State: <span id="debug-drag-state">IDLE</span></p>
						<p>Target: <span id="debug-drag-target">None</span></p>
					</div>
					<div class="debug-section">
						<h4>Gesture Data</h4>
						<div id="debug-gesture-data">N/A</div>
					</div>
				</div>
			</div>
			<div id="paused-overlay">
				<h2>Paused</h2>
				<p>Click anywhere to resume</p>
			</div>
			<canvas id="hand-canvas"></canvas>
			<video id="webcam" autoplay playsinline></video>
			<div id="interaction-layer">
				<div id="box1" class="draggable">Red</div>
				<div id="box2" class="draggable">Green</div>
				<div id="box3" class="draggable">Blue</div>
			</div>
			<div id="cursor"></div>
			<div id="status">Initializing Handpose...</div>
		</div>

		<script>
			import { init } from '../scripts/main.js';
			init();
		</script>
	</body>
</html>
